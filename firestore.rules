rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // Helpers
    // ─────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    // Lowercased so it matches admin docs keyed by a normalized email.
    function userEmail() {
      return request.auth.token.email.lower();
    }

    // Admin docs are keyed by the admin's email (see scripts/migrate-admins.js).
    // exists() is cheap and never throws, unlike get().data on a missing doc.
    function adminDoc() {
      return get(/databases/$(database)/documents/admins/$(userEmail()));
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/admins/$(userEmail()));
    }

    function isSuperAdmin() {
      return isAdmin() && adminDoc().data.role == 'super_admin';
    }

    // Field-level guards
    function isString(v, max) {
      return v is string && v.size() <= max;
    }

    // ─────────────────────────────────────────────────────────────
    // users — owner or admin only. Protects PII (phone, DOB, visa,
    // passport expiry, measurements, health notes, photos).
    // ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
    }

    // user_skills — owner or admin only
    match /user_skills/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // ─────────────────────────────────────────────────────────────
    // admins — a user may read ONLY their own admin doc (to discover
    // their own role cheaply); admins may read all; super admins write.
    // ─────────────────────────────────────────────────────────────
    match /admins/{adminEmail} {
      allow read: if isAuthenticated()
                    && (adminEmail == userEmail() || isAdmin());
      allow create, update, delete: if isSuperAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // jobs — public read; admins write their own (super admins, any)
    // ─────────────────────────────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if isAdmin()
                      && request.resource.data.postedBy == userEmail();
      allow update, delete: if isAdmin()
                      && (isSuperAdmin() || resource.data.postedBy == userEmail());
    }

    // ─────────────────────────────────────────────────────────────
    // applications — applicant creates own; applicant + admin read;
    // only admins change status.
    // ─────────────────────────────────────────────────────────────
    match /applications/{appId} {
      allow create: if isAuthenticated()
                      && request.resource.data.userEmail == userEmail()
                      && request.resource.data.userId == request.auth.uid
                      && isString(request.resource.data.jobId, 200)
                      && isString(request.resource.data.whyYou, 5000);
      allow read: if isAuthenticated()
                    && (isAdmin() || resource.data.userEmail == userEmail());
      allow update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // staff_inquiries / leads — auth users create; admins manage.
    // (leads also written in bulk by admins via CSV import)
    // ─────────────────────────────────────────────────────────────
    match /staff_inquiries/{inquiryId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /leads/{leadId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // settings (company profile) — admins only
    match /settings/{settingId} {
      allow read: if true; // public company info shown on site
      allow write: if isAdmin();
    }

    // activity logs — admins read; created by admin actions
    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // logs are immutable
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
