# ============================================================
# Eventopic — Environment Variables Template
# ============================================================
# 1. Copy this file to .env.local:   cp .env.example .env.local
# 2. Fill in your real values.
# 3. NEVER commit .env.local (already covered by .gitignore).
#
# NOTE on NEXT_PUBLIC_*  : these are bundled into the browser and are
#   PUBLIC. Anyone can read them in DevTools. That is normal for Firebase
#   web config, but it means your real security MUST live in Firestore
#   Security Rules — never assume a NEXT_PUBLIC value is a secret.
# Variables WITHOUT the NEXT_PUBLIC_ prefix stay server-only (safe secrets).
# ============================================================


# ------------------------------------------------------------
# 1) Firebase — Client SDK (public web config)
#    Firebase Console > Project Settings > General > Your apps
# ------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456


# ------------------------------------------------------------
# 2) Firebase — Admin SDK (SERVER-ONLY SECRET, do not expose)
#    Firebase Console > Project Settings > Service Accounts >
#    Generate new private key. Copy values from the downloaded JSON.
#    The private key must keep its \n line breaks and be wrapped in quotes.
# ------------------------------------------------------------
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"


# ------------------------------------------------------------
# 3) OpenAI — powers the AI chatbot (SERVER-ONLY SECRET)
#    Required by app/api/chat/route.ts. Get from platform.openai.com.
#    >>> This was missing from the old template but the app needs it. <<<
# ------------------------------------------------------------
OPENAI_API_KEY=sk-your_openai_api_key_here


# ------------------------------------------------------------
# 4) Cloudinary — profile photo & CV uploads
#    Cloudinary Dashboard. The upload preset MUST be UNSIGNED for the
#    browser upload in app/profile/page.tsx to work.
# ------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset


# ------------------------------------------------------------
# 5) Admin bootstrapping
#    Comma-separated emails seeded as the first super-admins the first
#    time the admins collection is empty. After that, manage admins in
#    the Admin Portal. Keep this list small.
# ------------------------------------------------------------
NEXT_PUBLIC_ADMIN_EMAILS=owner@eventopic.com


# ------------------------------------------------------------
# 6) Analytics
#    Google Analytics 4 Measurement ID (used in app/layout.tsx).
# ------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX


# ------------------------------------------------------------
# 7) Rate limiting — Upstash Redis (RECOMMENDED for production)
#    The current in-memory rate limiter does NOT work on Vercel/serverless
#    (each request can hit a fresh instance with an empty counter).
#    Create a free Redis at console.upstash.com and fill these in to make
#    rate limiting actually effective in production.
# ------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here
